# Telegram Bot Token — @BotFather dan oling
BOT_TOKEN=your_telegram_bot_token_here

# Django maxfiy kalit — ishlab chiqarish uchun o'zgartiring
DJANGO_SECRET_KEY=django-insecure-change-this-in-production

# Railway deploy qilingandan keyin bu URL ni yangilang
APP_URL=https://your-app.railway.app

# Production uchun False qoldiring
DEBUG=False

# PostgreSQL — Railway PostgreSQL plugin qo'shilganda DATABASE_URL avtomatik to'ldiriladi
# Yoki alohida o'zgaruvchilar bilan:
DATABASE_URL=postgresql://user:password@host:5432/real_holat

# Lokal ishlatish uchun (DATABASE_URL bo'lmasa):
# PGDATABASE=real_holat
# PGUSER=postgres
# PGPASSWORD=your_password
# PGHOST=localhost
# PGPORT=5432

# Monitoring
MONITORING_ESKIRISH_KUNI=90
